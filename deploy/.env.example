# Environment variables for deployment

# General settings
REGION=us-east-1

# S3 Bucket settings
BUCKET_NAME=flink-flight-analysis
DEPLOY_FOLDER_NAME=deploy

# SSH Key Configuration
SSH_KEY_NAME=flink-cluster-key
SSH_KEY_DIR=..\keys

# Network Configuration
VPC_NAME=Flight-Stream-VPC
SUBNET_NAME=Flight-Stream-Subnet
VPC_CIDR=10.0.0.0/16
SUBNET_CIDR=10.0.1.0/24
SG_NAME=Flight-Stream-SG
PRIVATE_DOMAIN_NAME=flight-analysis.local

# Flink and Kafka Cluster Configuration
KAFKA_COUNT=3
FLINK_WORKER_COUNT=3

# Services Ports
KAFKA_PORT=9094
FLINK_PORT=8081
INFLUXDB_PORT=8086
GRAFANA_PORT=3000

# Credentials
GRAFANA_USER=admin
GRAFANA_PASS=admin

INFLUXDB_USER=admin
INFLUXDB_PASS=admin123
INFLUXDB_ORG=sae-org
INFLUXDB_RESULTS_BUCKET=flights-data
INFLUXDB_METRICS_BUCKET=flink-metrics
