      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Q1: Airline Departure Delay Performance (Trend)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "influxdb-v2"
                      },
                      "spec": {
                        "query": "from(bucket: \"flights-data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"flight_analysis_results\")\n  |> filter(fn: (r) => r.airline == \"AA\" or r.airline == \"DL\" or r.airline == \"UA\" or r.airline == \"WN\")\n  |> filter(fn: (r) => r[\"_field\"] == \"dep_delay_mean\")\n  |> group(columns: [\"airline\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"Delay Mean\")"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
