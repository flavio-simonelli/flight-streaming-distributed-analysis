                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "influxdb-v2"
                      },
                      "spec": {
                        "query": "from(bucket: \"flink-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] =~ /.*latency.*/)\n|> filter(fn: (r) => r[\"_field\"] == \"min\" or r[\"_field\"] == \"mean\" or r[\"_field\"] == \"max\" or r[\"_field\"] == \"p50\" or r[\"_field\"] == \"p75\" or r[\"_field\"] == \"p95\" or r[\"_field\"] == \"p999\")  |> keep(columns: [\"_time\", \"_value\", \"_field\", \"_measurement\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"Latenza\")"
                      }
                    },
