        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-v2"
          },
          "query": "from(bucket: \"flights-data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] =~ /.*numRecordsOutPerSecond$/)\n  |> filter(fn: (r) => r[\"_field\"] == \"rate\" or r[\"_field\"] == \"count\" or r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"Throughput\")",
          "refId": "A"
        }
      ],
      "title": "Flink Throughput (Records/s)",
      "type": "timeseries"
    },
