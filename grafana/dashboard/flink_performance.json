      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Flink Throughput (Records/s)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "influxdb-v2"
                      },
                      "spec": {
                        "query": "from(bucket: \"flink-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] =~ /^taskmanager_job_task_numRecordsOutPerSecond$/)\n  |> filter(fn: (r) => r[\"_field\"] == \"rate\")\n  |> keep(columns: [\"_time\", \"_value\", \"_field\", \"_measurement\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> yield(name: \"Throughput\")"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
