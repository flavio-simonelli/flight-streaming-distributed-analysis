# Flight simulator configuration
#
# Update these values to point the simulator to the input dataset and to the
# desired output target. The defaults below are suitable for local or Docker
# based development.
#
# Special behaviors:
# - MAX_RECORDS=0 means no limit: the simulator will process the entire dataset.
# - SPEEDUP_FACTOR scales down the real delay between records.
#   Example: with SPEEDUP_FACTOR=100000, 1 second of real flight time becomes
#   1/100000 second of simulated waiting time.
INPUT_PARQUET_PATH=./data/flights.parquets
OUTPUT_TYPE=kafka
MAX_RECORDS=50
SPEEDUP_FACTOR=100000

# Kafka connection settings
#
# Used only when OUTPUT_TYPE is set to kafka.
# Brokers must be provided as host:port values, separated by commas if needed.
KAFKA_BROKERS=kafka.flight-analysis.local:9094
KAFKA_TOPIC=flights-stream
 
# Active spin threshold (milliseconds)
# The final portion of the waiting interval is spent in an active spin to
# improve timing precision. This value sets that threshold in milliseconds.
# Example: 2 means the last 2ms of the wait are done with active spinning.
SPIN_THRESHOLD_MS=2

# Out-of-order injection settings
#
# These settings simulate the behavior of geographically distributed sensors
# that may publish events with variable network latency, causing records to
# arrive out of order relative to their logical event time.
#
# OUT_OF_ORDER_FACTOR: probability [0.0, 1.0] that any given record will be
#   delayed before publication. 0.0 disables out-of-order injection entirely.
#   Example: 0.1 means roughly 10% of records are artificially delayed.
#
# OUT_OF_ORDER_MAX_DELAY_MINUTES: upper bound for the random artificial delay,
#   expressed in logical event-time minutes to match the minute-level granularity
#   of flight timestamps (CRS_DEP_TIME has no seconds). The actual wall-clock
#   delay is scaled by SPEEDUP_FACTOR, so it stays proportional to the simulation:
#     real_delay = rand(OUT_OF_ORDER_MAX_DELAY_MINUTES) * 60s / SPEEDUP_FACTOR
#   Example: 5 means a delayed record can appear up to 5 simulated minutes late.
OUT_OF_ORDER_FACTOR=0.0
OUT_OF_ORDER_MAX_DELAY_MINUTES=5
